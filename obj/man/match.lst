                             42 .area _DATA
                             43 
   0000                      44 man_match_player1:: .ds sizeof_Player
   0006                      45 man_match_player2:: .ds sizeof_Player
   000C 01                   46 man_match_num_players:: .db 1
                             47 
                             48 ;;
                             49 ;; Board: 6x6 cells, row-major [row*6 + col]
                             50 ;; Values: 0=empty, 1=P1 cat, 2=P1 kitten, 3=P2 cat, 4=P2 kitten
                             51 ;;
   000D                      52 _match_board: .ds 36
                             53 
