                           1579 ;;
                           1580 ;; _match_check_no_pieces
                           1581 ;;
                           1582 ;;  Called after each placement. Checks whether the next player has
                           1583 ;;  no cats and no kittens in reserve. If so, the opposite player
                           1584 ;;  wins via _match_declare_winner.
                           1585 ;;  Input:  _match_state = next player (0=P1, 1=P2, already toggled)
                           1586 ;;  Output: -
                           1587 ;;  Modified: AF, IX
                           1588 ;;
   0714                    1589 _match_check_no_pieces:
   0714 3A 32 00      [13] 1590    ld a, (_match_state)
   0717 B7            [ 4] 1591    or a
   0718 20 06         [12] 1592    jr nz, _mcnp_p2
   071A DD 21 00 00   [14] 1593    ld ix, #man_match_player1
   071E 18 04         [12] 1594    jr _mcnp_chk
   0720                    1595 _mcnp_p2:
   0720 DD 21 06 00   [14] 1596    ld ix, #man_match_player2
   0724                    1597 _mcnp_chk:
   0724 DD 7E 04      [19] 1598    ld a, Player_cats(ix)
   0727 B7            [ 4] 1599    or a
   0728 C0            [11] 1600    ret nz                            ;; still has cats
   0729 DD 7E 05      [19] 1601    ld a, Player_kittens(ix)
   072C B7            [ 4] 1602    or a
   072D C0            [11] 1603    ret nz                            ;; still has kittens
                           1604 
                           1605    ;; state=0 (P1 out) → P2 wins; state=1 (P2 out) → P1 wins
                           1606    ;; winner = (state XOR 1) + 1: state=0→2, state=1→1
   072E 3A 32 00      [13] 1607    ld a, (_match_state)
   0731 EE 01         [ 7] 1608    xor #1
   0733 3C            [ 4] 1609    inc a
   0734 C3 17 06      [10] 1610    jp _match_declare_winner
