                           1167 ;;-----------------------------------------------------------------
                           1168 ;;
                           1169 ;; _mrl_process_kitten
                           1170 ;;
                           1171 ;;  For a single board cell: if it holds a kitten (even value),
                           1172 ;;  clears it and gives the owner +1 cat. If it holds a cat (odd),
                           1173 ;;  does nothing (cats remain in place).
                           1174 ;;  Input:  HL = board cell pointer
                           1175 ;;          A  = cell value (must be non-zero)
                           1176 ;;  Output: -
                           1177 ;;  Modified: AF, IX
                           1178 ;;
   0547                    1179 _mrl_process_kitten:
   0547 CB 47         [ 8] 1180    bit 0, a                          ;; odd = cat → nothing to do
   0549 C0            [11] 1181    ret nz
                           1182    ;; even = kitten: clear cell and award 1 cat to owner
   054A 36 00         [10] 1183    ld (hl), #BOARD_EMPTY
   054C FE 04         [ 7] 1184    cp #BOARD_P2_KITTEN
   054E 28 06         [12] 1185    jr z, _mpk_p2
   0550 DD 21 00 00   [14] 1186    ld ix, #man_match_player1
   0554 18 04         [12] 1187    jr _mpk_add
   0556                    1188 _mpk_p2:
   0556 DD 21 06 00   [14] 1189    ld ix, #man_match_player2
   055A                    1190 _mpk_add:
   055A DD 34 04      [23] 1191    inc Player_cats(ix)
   055D C9            [10] 1192    ret
                           1193 
