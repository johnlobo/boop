   020D 3A 32 00      [13]  551    ld a, (_match_state)
   0210 EE 01         [ 7]  552    xor #1
   0212 32 32 00      [13]  553    ld (_match_state), a
   0215 B7            [ 4]  554    or a
   0216 20 06         [12]  555    jr nz, _mpp_init_p2
   0218 DD 21 00 00   [14]  556    ld ix, #man_match_player1
