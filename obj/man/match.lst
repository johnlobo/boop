   06D1 87            [ 4] 1521    add a, a
   06D2 80            [ 4] 1522    add a, b
   06D3 80            [ 4] 1523    add a, b
   06D4 81            [ 4] 1524    add a, c
   06D5 21 0D 00      [10] 1525    ld hl, #_match_board
   06D8 16 00         [ 7] 1526    ld d, #0
   06DA 5F            [ 4] 1527    ld e, a
   06DB 19            [11] 1528    add hl, de                        ;; HL = &board[row][col]
                           1529 
   06DC 7E            [ 7] 1530    ld a, (hl)
   06DD 57            [ 4] 1531    ld d, a                           ;; D = v0
   06DE FE 01         [ 7] 1532    cp #BOARD_P1_CAT
   06E0 28 04         [12] 1533    jr z, _mccl_v_chk
   06E2 FE 03         [ 7] 1534    cp #BOARD_P2_CAT
   06E4 20 20         [12] 1535    jr nz, _mccl_v_next
                           1536 
   06E6                    1537 _mccl_v_chk:
   06E6 E5            [11] 1538    push hl                           ;; [ptr0, BC_outer]
   06E7 01 06 00      [10] 1539    ld bc, #GRID_COLS
   06EA 09            [11] 1540    add hl, bc                        ;; HL = ptr1
   06EB 7E            [ 7] 1541    ld a, (hl)
   06EC BA            [ 4] 1542    cp d
   06ED 20 16         [12] 1543    jr nz, _mccl_v_nm1
   06EF E5            [11] 1544    push hl                           ;; [ptr1, ptr0, BC_outer]
   06F0 09            [11] 1545    add hl, bc                        ;; HL = ptr2
   06F1 7E            [ 7] 1546    ld a, (hl)
   06F2 BA            [ 4] 1547    cp d
   06F3 20 0F         [12] 1548    jr nz, _mccl_v_nm2
                           1549    ;; Match
   06F5 E1            [10] 1550    pop hl                            ;; pop ptr1
   06F6 E1            [10] 1551    pop hl                            ;; pop ptr0
   06F7 C1            [10] 1552    pop bc                            ;; restore outer BC
   06F8 7A            [ 4] 1553    ld a, d
   06F9 FE 03         [ 7] 1554    cp #BOARD_P2_CAT
   06FB 3E 01         [ 7] 1555    ld a, #1
   06FD 20 02         [12] 1556    jr nz, _mccl_v_declare
   06FF 3E 02         [ 7] 1557    ld a, #2
   0701                    1558 _mccl_v_declare:
   0701 C3 17 06      [10] 1559    jp _match_declare_winner
