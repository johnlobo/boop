   0406 DD 4E 00      [19]  887    ld c, 0(ix)                       ;; board cell offset (0..35)
   0409 06 00         [ 7]  888    ld b, #0
   040B 21 0D 00      [10]  889    ld hl, #_match_board
   040E 09            [11]  890    add hl, bc                        ;; HL = &board[offset]
   040F DD 7E 01      [19]  891    ld a, 1(ix)                       ;; piece value
