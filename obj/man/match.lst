                            115 ;;
                            116 ;; _match_init_player
                            117 ;;
                            118 ;;  Zeroes score and sets cats, kittens for one player struct
                            119 ;;  Input:  HL = pointer to player struct
                            120 ;;  Output:
                            121 ;;  Modified: AF, IX
                            122 ;;
   0000                     123 _match_init_player:
   0000 E5            [11]  124    push hl
ASxxxx Assembler V02.00 + NoICE + SDCC mods  (Zilog Z80 / Hitachi HD64180), page 108.
Hexadecimal [16-Bits]



   0001 DD E1         [14]  125    pop ix                            ;; IX = player struct pointer (IX supports displacement)
   0003 AF            [ 4]  126    xor a
   0004 DD 77 00      [19]  127    ld Player_score+0(ix), a
   0007 DD 77 01      [19]  128    ld Player_score+1(ix), a
   000A DD 77 02      [19]  129    ld Player_score+2(ix), a
   000D DD 77 03      [19]  130    ld Player_score+3(ix), a
   0010 3E 00         [ 7]  131    ld a, #MATCH_INITIAL_CATS
   0012 DD 77 04      [19]  132    ld Player_cats(ix), a
   0015 3E 08         [ 7]  133    ld a, #MATCH_INITIAL_KITTENS
   0017 DD 77 05      [19]  134    ld Player_kittens(ix), a
   001A C9            [10]  135    ret
                            136 
                            137 ;;-----------------------------------------------------------------
                            138 ;;
                            139 ;; _draw_big_digit
                            140 ;;
                            141 ;;  Draws a single big number sprite at the given screen address.
                            142 ;;  Input:  A  = digit (0-9)
                            143 ;;          DE = screen destination address
                            144 ;;  Output:
                            145 ;;  Modified: AF, BC, HL
                            146 ;;
   001B                     147 _draw_big_digit:
   001B D5            [11]  148    push de                           ;; save dest while computing sprite ptr
   001C 21 83 00      [10]  149    ld hl, #_big_num_ptrs
   001F 06 00         [ 7]  150    ld b, #0
   0021 4F            [ 4]  151    ld c, a
   0022 CB 21         [ 8]  152    sla c                             ;; C = digit * 2 (each table entry = 2 bytes)
   0024 CB 10         [ 8]  153    rl b                              ;; carry into B (always 0 for digits 0-9)
   0026 09            [11]  154    add hl, bc                        ;; HL = &_big_num_ptrs[digit * 2]
   0027 4E            [ 7]  155    ld c, (hl)
   0028 23            [ 6]  156    inc hl
   0029 46            [ 7]  157    ld b, (hl)                        ;; BC = sprite data pointer
   002A D1            [10]  158    pop de                            ;; restore dest
   002B                     159    ld__ixl S_BIG_NUMBERS_W
   002B DD 2E 03              1    .db #0xDD, #0x2E, S_BIG_NUMBERS_W  ;; Opcode for ld ixl, Value
   002E                     160    ld__ixh S_BIG_NUMBERS_H
   002E DD 26 0D              1    .db #0xDD, #0x26, S_BIG_NUMBERS_H  ;; Opcode for ld ixh, Value
   0031 21 00 00      [10]  161    ld hl, #transparency_table
   0034 CD 00 00      [17]  162    call cpct_drawSpriteMaskedAlignedTable_asm
   0037 C9            [10]  163    ret
                            164 
