                            501    ;; CAT
   01CC DD 7E 04      [19]  502    ld a, Player_cats(ix)
   01CF B7            [ 4]  503    or a
   01D0 C8            [11]  504    ret z                             ;; no cats left
   01D1 3D            [ 4]  505    dec a
   01D2 DD 77 04      [19]  506    ld Player_cats(ix), a
   01D5 18 09         [12]  507    jr _mpp_do_place
