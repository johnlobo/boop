                           1432    ;; init player 2
   061E 21 06 00      [10] 1433    ld hl, #man_match_player2
   0621 CD 00 00      [17] 1434    call _match_init_player
                           1435 
                           1436    ;; clear board (36 bytes) using ldir memset pattern
   0624 21 0D 00      [10] 1437    ld hl, #_match_board
   0627 11 0E 00      [10] 1438    ld de, #(_match_board + 1)
   062A 01 23 00      [10] 1439    ld bc, #35
   062D 36 00         [10] 1440    ld (hl), #BOARD_EMPTY
   062F ED B0         [21] 1441    ldir
                           1442 
                           1443    ;; initialise cursor, turn state and cancel flag
   0631 AF            [ 4] 1444    xor a
   0632 32 31 00      [13] 1445    ld (_match_cancelled), a
   0635 32 32 00      [13] 1446    ld (_match_state), a
   0638 32 33 00      [13] 1447    ld (_cursor_col), a
   063B 32 34 00      [13] 1448    ld (_cursor_row), a
   063E 3E 01         [ 7] 1449    ld a, #PIECE_KITTEN               ;; start with kitten selected
   0640 32 35 00      [13] 1450    ld (_cursor_piece), a
   0643 AF            [ 4] 1451    xor a
   0644 32 36 00      [13] 1452    ld (_turn_debounce), a
                           1453 
                           1454    ;; draw full screen: static elements once, then grid + board + cursor + HUD
   0647 CD 00 00      [17] 1455    call sys_render_draw_screen
   064A CD 95 01      [17] 1456    call _match_redraw_all
   064D CD 38 00      [17] 1457    call man_match_draw_hud
                           1458 
   0650 C9            [10] 1459    ret
