   0034 00                   60 _cursor_row:    .db 0   ;; 0 .. GRID_ROWS-1
   0035 00                   61 _cursor_piece:  .db 0   ;; PIECE_CAT or PIECE_KITTEN
   0036 00                   62 _turn_debounce: .db 0   ;; 1 while a key is held (same pattern as menu.s)
