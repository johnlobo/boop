                           1379 ;;
                           1380 ;; _match_check_no_pieces
                           1381 ;;
                           1382 ;;  Called after each placement. Checks whether the next player has
                           1383 ;;  no cats and no kittens in reserve. If so, the opposite player
                           1384 ;;  wins via _match_declare_winner.
                           1385 ;;  Input:  _match_state = next player (0=P1, 1=P2, already toggled)
                           1386 ;;  Output: -
                           1387 ;;  Modified: AF, IX
                           1388 ;;
   05EF                    1389 _match_check_no_pieces:
   05EF 3A 32 00      [13] 1390    ld a, (_match_state)
   05F2 B7            [ 4] 1391    or a
   05F3 20 06         [12] 1392    jr nz, _mcnp_p2
   05F5 DD 21 00 00   [14] 1393    ld ix, #man_match_player1
   05F9 18 04         [12] 1394    jr _mcnp_chk
   05FB                    1395 _mcnp_p2:
   05FB DD 21 06 00   [14] 1396    ld ix, #man_match_player2
   05FF                    1397 _mcnp_chk:
   05FF DD 7E 04      [19] 1398    ld a, Player_cats(ix)
   0602 B7            [ 4] 1399    or a
   0603 C0            [11] 1400    ret nz                            ;; still has cats
   0604 DD 7E 05      [19] 1401    ld a, Player_kittens(ix)
   0607 B7            [ 4] 1402    or a
   0608 C0            [11] 1403    ret nz                            ;; still has kittens
                           1404 
                           1405    ;; state=0 (P1 out) → P2 wins; state=1 (P2 out) → P1 wins
                           1406    ;; winner = (state XOR 1) + 1: state=0→2, state=1→1
   0609 3A 32 00      [13] 1407    ld a, (_match_state)
   060C EE 01         [ 7] 1408    xor #1
   060E 3C            [ 4] 1409    inc a
   060F C3 36 05      [10] 1410    jp _match_declare_winner
                           1411 
