   01F1 3A 32 00      [13]  534    ld a, (_match_state)              ;; still = placing player (not yet toggled)
   01F4 B7            [ 4]  535    or a
   01F5 20 06         [12]  536    jr nz, _mpp_pe_p2
   01F7 DD 21 00 00   [14]  537    ld ix, #man_match_player1
   01FB 18 04         [12]  538    jr _mpp_pe_chk
