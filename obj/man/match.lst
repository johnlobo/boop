                            331 ;;-----------------------------------------------------------------
                            332 ;;
                            333 ;; _match_draw_board
                            334 ;;
                            335 ;;  Iterates all 6x6 cells and draws sprites for non-empty ones.
                            336 ;;  Input:
                            337 ;;  Output:
                            338 ;;  Modified: AF, BC, DE, HL, IX
                            339 ;;
   0117                     340 _match_draw_board:
   0117 DD 21 0D 00   [14]  341    ld ix, #_match_board
   011B 06 00         [ 7]  342    ld b, #0                          ;; B = row
   011D                     343 _mdb_row_loop:
   011D 0E 00         [ 7]  344    ld c, #0                          ;; C = col
   011F                     345 _mdb_col_loop:
   011F DD 7E 00      [19]  346    ld a, 0(ix)                       ;; A = cell value
   0122 DD 23         [10]  347    inc ix                            ;; advance board pointer
   0124 B7            [ 4]  348    or a
   0125 28 0F         [12]  349    jr z, _mdb_next_col               ;; skip empty cells
                            350 
   0127 DD E5         [15]  351    push ix                           ;; save board pointer (clobbered by sprite draw)
   0129 C5            [11]  352    push bc                           ;; save row (B) and col (C)
   012A F5            [11]  353    push af                           ;; save cell value
   012B CD DF 00      [17]  354    call _match_col_row_to_screen_addr ;; B=row, C=col -> DE = screen addr
   012E F1            [10]  355    pop af                            ;; A = cell value
   012F 13            [ 6]  356    inc de                            ;; shift sprite 1 byte (2px) right, same as cursor
   0130 CD F9 00      [17]  357    call _match_draw_cell_sprite
   0133 C1            [10]  358    pop bc                            ;; restore row/col
   0134 DD E1         [14]  359    pop ix                            ;; restore board pointer
                            360 
   0136                     361 _mdb_next_col:
   0136 0C            [ 4]  362    inc c
   0137 79            [ 4]  363    ld a, c
   0138 FE 06         [ 7]  364    cp #GRID_COLS
   013A 38 E3         [12]  365    jr c, _mdb_col_loop
                            366 
   013C 04            [ 4]  367    inc b
   013D 78            [ 4]  368    ld a, b
   013E FE 06         [ 7]  369    cp #GRID_ROWS
   0140 38 DB         [12]  370    jr c, _mdb_row_loop
                            371 
   0142 C9            [10]  372    ret
                            373 
