                             78 ;;
                             79 ;; Direction table for boop: 8 (dr, dc) pairs (signed bytes, 0xFF = -1)
                             80 ;;
   00C4                      81 _boop_dir_table:
   00C4 FF FF                82    .db 0xFF, 0xFF   ;; (-1,-1)
   00C6 FF 00                83    .db 0xFF, 0x00   ;; (-1, 0)
   00C8 FF 01                84    .db 0xFF, 0x01   ;; (-1,+1)
   00CA 00 FF                85    .db 0x00, 0xFF   ;;  (0,-1)
   00CC 00 01                86    .db 0x00, 0x01   ;;  (0,+1)
   00CE 01 FF                87    .db 0x01, 0xFF   ;; (+1,-1)
   00D0 01 00                88    .db 0x01, 0x00   ;; (+1, 0)
   00D2 01 01                89    .db 0x01, 0x01   ;; (+1,+1)
                             90 
                             91 ;;
                             92 ;; Lookup table: 16-bit pointers to big number sprites 0-9
                             93 ;;
   00D4                      94 _big_num_ptrs:
   00D4 00 00                95    .dw _s_big_numbers_00
   00D6 00 00                96    .dw _s_big_numbers_01
   00D8 00 00                97    .dw _s_big_numbers_02
   00DA 00 00                98    .dw _s_big_numbers_03
   00DC 00 00                99    .dw _s_big_numbers_04
   00DE 00 00               100    .dw _s_big_numbers_05
   00E0 00 00               101    .dw _s_big_numbers_06
   00E2 00 00               102    .dw _s_big_numbers_07
   00E4 00 00               103    .dw _s_big_numbers_08
   00E6 00 00               104    .dw _s_big_numbers_09
                            105 
                            106 ;;
                            107 ;; Lookup table: sprite pointers for board cell values 1-4
                            108 ;;   index 0 (value 1) -> P1 cat
                            109 ;;   index 1 (value 2) -> P1 kitten
                            110 ;;   index 2 (value 3) -> P2 cat
                            111 ;;   index 3 (value 4) -> P2 kitten
                            112 ;;
   00E8                     113 _board_sprite_ptrs:
   00E8 00 00               114    .dw _s_cat_0
   00EA 00 00               115    .dw _s_catty_0
   00EC 00 00               116    .dw _s_cat_1
   00EE 00 00               117    .dw _s_catty_1
                            118 
