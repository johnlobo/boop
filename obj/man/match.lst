                            364 ;;-----------------------------------------------------------------
                            365 ;;
                            366 ;; _match_draw_cursor
                            367 ;;
                            368 ;;  Draws the cursor: yellow solid box with current piece sprite on top.
                            369 ;;  Input:
                            370 ;;  Output:
                            371 ;;  Modified: AF, BC, DE, HL, IX
                            372 ;;
   0143                     373 _match_draw_cursor:
                            374    ;; Compute screen address for cursor position
   0143 3A 33 00      [13]  375    ld a, (_cursor_col)
   0146 4F            [ 4]  376    ld c, a
   0147 3A 34 00      [13]  377    ld a, (_cursor_row)
   014A 47            [ 4]  378    ld b, a
   014B CD DF 00      [17]  379    call _match_col_row_to_screen_addr  ;; DE = screen addr
   014E 13            [ 6]  380    inc de                              ;; shift cursor 1 byte (2px) right within cell
                            381 
