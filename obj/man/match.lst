   0565 87            [ 4] 1223    add a, a                          ;; row*4
   0566 80            [ 4] 1224    add a, b                          ;; row*5
   0567 80            [ 4] 1225    add a, b                          ;; row*6
   0568 81            [ 4] 1226    add a, c
   0569 21 0D 00      [10] 1227    ld hl, #_match_board
   056C 16 00         [ 7] 1228    ld d, #0
   056E 5F            [ 4] 1229    ld e, a
