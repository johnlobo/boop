                            900 ;;-----------------------------------------------------------------
                            901 ;;
                            902 ;; _match_boop
                            903 ;;
                            904 ;;  Called after placing a kitten at (_cursor_row, _cursor_col).
                            905 ;;  For each of 8 neighbor directions: if the neighbor cell holds a
                            906 ;;  kitten, it is pushed one cell further away (neighbor + delta).
                            907 ;;  If the destination is off-grid the kitten is removed from the
                            908 ;;  board and its owner's Player_kittens count is incremented.
                            909 ;;  If the destination is occupied the kitten stays in place.
                            910 ;;  Cats (BOARD_P1_CAT / BOARD_P2_CAT) are never affected.
                            911 ;;  Input:  _cursor_row, _cursor_col = placed kitten position
                            912 ;;  Output:
                            913 ;;  Modified: AF, BC, DE, HL, IX, IY
                            914 ;;
   041C                     915 _match_boop:
   041C FD 21 C4 00   [14]  916    ld iy, #_boop_dir_table
   0420 06 08         [ 7]  917    ld b, #8                          ;; 8 directions to check
                            918 
   0422                     919 _mb_dir_loop:
   0422 C5            [11]  920    push bc                           ;; save loop counter
ASxxxx Assembler V02.00 + NoICE + SDCC mods  (Zilog Z80 / Hitachi HD64180), page 124.
Hexadecimal [16-Bits]



                            921 
                            922    ;; -- compute neighbor row: nr = cursor_row + dr --
   0423 3A 34 00      [13]  923    ld a, (_cursor_row)
   0426 FD 86 00      [19]  924    add a, 0(iy)
   0429 FA A7 04      [10]  925    jp m, _mb_next_dir                ;; nr < 0 → out of bounds
   042C 57            [ 4]  926    ld d, a                           ;; D = nr
   042D FE 06         [ 7]  927    cp #GRID_ROWS
   042F 30 76         [12]  928    jr nc, _mb_next_dir               ;; nr >= 6 → out of bounds
                            929 
                            930    ;; -- compute neighbor col: nc = cursor_col + dc --
   0431 3A 33 00      [13]  931    ld a, (_cursor_col)
   0434 FD 86 01      [19]  932    add a, 1(iy)
   0437 FA A7 04      [10]  933    jp m, _mb_next_dir                ;; nc < 0 → out of bounds
   043A 5F            [ 4]  934    ld e, a                           ;; E = nc
   043B FE 06         [ 7]  935    cp #GRID_COLS
   043D 30 68         [12]  936    jr nc, _mb_next_dir               ;; nc >= 6 → out of bounds
                            937 
                            938    ;; -- look up board[nr][nc] (index = nr*6 + nc) --
   043F 7A            [ 4]  939    ld a, d
   0440 87            [ 4]  940    add a, a                          ;; row*2
   0441 87            [ 4]  941    add a, a                          ;; row*4
   0442 82            [ 4]  942    add a, d                          ;; row*5
   0443 82            [ 4]  943    add a, d                          ;; row*6
   0444 83            [ 4]  944    add a, e
   0445 21 0D 00      [10]  945    ld hl, #_match_board
   0448 4F            [ 4]  946    ld c, a
   0449 06 00         [ 7]  947    ld b, #0
   044B 09            [11]  948    add hl, bc                        ;; HL = &board[nr][nc]
                            949 
   044C 7E            [ 7]  950    ld a, (hl)
   044D FE 02         [ 7]  951    cp #BOARD_P1_KITTEN
   044F 28 04         [12]  952    jr z, _mb_is_kitten
   0451 FE 04         [ 7]  953    cp #BOARD_P2_KITTEN
   0453 20 52         [12]  954    jr nz, _mb_next_dir               ;; not a kitten → nothing to push
                            955 
   0455                     956 _mb_is_kitten:
                            957    ;; A = kitten value (2 or 4); HL = source cell; D=nr, E=nc
   0455 E5            [11]  958    push hl                           ;; save source cell ptr
   0456 F5            [11]  959    push af                           ;; save kitten board value
                            960 
                            961    ;; -- destination = neighbor + same delta (pushed away from placed kitten) --
   0457 7A            [ 4]  962    ld a, d
   0458 FD 86 00      [19]  963    add a, 0(iy)                      ;; dest_row = nr + dr
   045B 57            [ 4]  964    ld d, a
   045C 7B            [ 4]  965    ld a, e
   045D FD 86 01      [19]  966    add a, 1(iy)                      ;; dest_col = nc + dc
   0460 5F            [ 4]  967    ld e, a
                            968 
                            969    ;; -- destination bounds check --
   0461 CB 7A         [ 8]  970    bit 7, d
   0463 20 2A         [12]  971    jr nz, _mb_dest_out               ;; dest_row negative
   0465 7A            [ 4]  972    ld a, d
   0466 FE 06         [ 7]  973    cp #GRID_ROWS
   0468 30 25         [12]  974    jr nc, _mb_dest_out               ;; dest_row >= 6
   046A CB 7B         [ 8]  975    bit 7, e
ASxxxx Assembler V02.00 + NoICE + SDCC mods  (Zilog Z80 / Hitachi HD64180), page 125.
Hexadecimal [16-Bits]



   046C 20 21         [12]  976    jr nz, _mb_dest_out               ;; dest_col negative
   046E 7B            [ 4]  977    ld a, e
   046F FE 06         [ 7]  978    cp #GRID_COLS
   0471 30 1C         [12]  979    jr nc, _mb_dest_out               ;; dest_col >= 6
                            980 
                            981    ;; -- destination in bounds: check if empty --
   0473 7A            [ 4]  982    ld a, d
   0474 87            [ 4]  983    add a, a                          ;; row*2
   0475 87            [ 4]  984    add a, a                          ;; row*4
   0476 82            [ 4]  985    add a, d                          ;; row*5
   0477 82            [ 4]  986    add a, d                          ;; row*6
   0478 83            [ 4]  987    add a, e
   0479 21 0D 00      [10]  988    ld hl, #_match_board
   047C 4F            [ 4]  989    ld c, a
   047D 06 00         [ 7]  990    ld b, #0
   047F 09            [11]  991    add hl, bc                        ;; HL = &board[dest_row][dest_col]
                            992 
   0480 7E            [ 7]  993    ld a, (hl)
   0481 B7            [ 4]  994    or a
   0482 20 07         [12]  995    jr nz, _mb_dest_blocked           ;; occupied → kitten stays
                            996 
                            997    ;; -- move kitten to empty destination --
