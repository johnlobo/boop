   0571 B7            [ 4] 1233    or a
   0572 28 32         [12] 1234    jr z, _mcl_h_next                 ;; empty → skip
   0574 57            [ 4] 1235    ld d, a                           ;; D = v0
   0575 FE 03         [ 7] 1236    cp #3
   0577 30 14         [12] 1237    jr nc, _mcl_h_v0_p2               ;; v0 >= 3 → P2 colour
                           1238 
