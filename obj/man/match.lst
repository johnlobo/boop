                           1443 ;;
                           1444 ;; _match_check_cat_lines
                           1445 ;;
                           1446 ;;  Scans every row and column for 3 consecutive cats of the same
                           1447 ;;  colour. If found, calls _match_declare_winner for that player.
                           1448 ;;  BOARD_P1_CAT=1 (odd) → P1 wins; BOARD_P2_CAT=3 (odd) → P2 wins.
                           1449 ;;
                           1450 ;;  Horizontal windows: col 0..3 in each row (0..5)
                           1451 ;;  Vertical   windows: row 0..3 in each col (0..5)
                           1452 ;;
ASxxxx Assembler V02.00 + NoICE + SDCC mods  (Zilog Z80 / Hitachi HD64180), page 134.
Hexadecimal [16-Bits]



                           1453 ;;  Input:  -
                           1454 ;;  Output: -
                           1455 ;;  Modified: AF, BC, DE, HL
                           1456 ;;
   0688                    1457 _match_check_cat_lines:
                           1458    ;; === Horizontal scan ===
   0688 06 00         [ 7] 1459    ld b, #0                          ;; B = row (0..5)
   068A                    1460 _mccl_h_rowloop:
   068A 0E 00         [ 7] 1461    ld c, #0                          ;; C = col window start (0..3)
   068C                    1462 _mccl_h_colloop:
   068C C5            [11] 1463    push bc
                           1464 
   068D 78            [ 4] 1465    ld a, b
   068E 87            [ 4] 1466    add a, a                          ;; row*2
   068F 87            [ 4] 1467    add a, a                          ;; row*4
   0690 80            [ 4] 1468    add a, b                          ;; row*5
   0691 80            [ 4] 1469    add a, b                          ;; row*6
   0692 81            [ 4] 1470    add a, c
   0693 21 0D 00      [10] 1471    ld hl, #_match_board
   0696 16 00         [ 7] 1472    ld d, #0
   0698 5F            [ 4] 1473    ld e, a
   0699 19            [11] 1474    add hl, de                        ;; HL = &board[row][col]
                           1475 
   069A 7E            [ 7] 1476    ld a, (hl)
   069B 57            [ 4] 1477    ld d, a                           ;; D = v0
   069C FE 01         [ 7] 1478    cp #BOARD_P1_CAT
   069E 28 04         [12] 1479    jr z, _mccl_h_chk
   06A0 FE 03         [ 7] 1480    cp #BOARD_P2_CAT
   06A2 20 19         [12] 1481    jr nz, _mccl_h_next
   06A4                    1482 _mccl_h_chk:
   06A4 23            [ 6] 1483    inc hl
   06A5 7E            [ 7] 1484    ld a, (hl)
   06A6 BA            [ 4] 1485    cp d
   06A7 20 14         [12] 1486    jr nz, _mccl_h_next
   06A9 23            [ 6] 1487    inc hl
   06AA 7E            [ 7] 1488    ld a, (hl)
   06AB BA            [ 4] 1489    cp d
   06AC 20 0F         [12] 1490    jr nz, _mccl_h_next
                           1491    ;; Match: 3 cats in a row
   06AE C1            [10] 1492    pop bc
   06AF 3E 01         [ 7] 1493    ld a, #1                          ;; default P1 wins (P1_CAT=1)
   06B1 7A            [ 4] 1494    ld a, d
   06B2 FE 03         [ 7] 1495    cp #BOARD_P2_CAT
   06B4 3E 01         [ 7] 1496    ld a, #1
   06B6 20 02         [12] 1497    jr nz, _mccl_declare
   06B8 3E 02         [ 7] 1498    ld a, #2
   06BA                    1499 _mccl_declare:
   06BA C3 17 06      [10] 1500    jp _match_declare_winner          ;; no return; sets _match_cancelled
   06BD                    1501 _mccl_h_next:
   06BD C1            [10] 1502    pop bc
   06BE 0C            [ 4] 1503    inc c
   06BF 79            [ 4] 1504    ld a, c
   06C0 FE 04         [ 7] 1505    cp #(GRID_COLS - 2)
   06C2 38 C8         [12] 1506    jr c, _mccl_h_colloop
   06C4 04            [ 4] 1507    inc b
ASxxxx Assembler V02.00 + NoICE + SDCC mods  (Zilog Z80 / Hitachi HD64180), page 135.
Hexadecimal [16-Bits]



   06C5 78            [ 4] 1508    ld a, b
   06C6 FE 06         [ 7] 1509    cp #GRID_ROWS
   06C8 38 C0         [12] 1510    jr c, _mccl_h_rowloop
                           1511 
                           1512    ;; === Vertical scan ===
   06CA 0E 00         [ 7] 1513    ld c, #0                          ;; C = col (0..5)
   06CC                    1514 _mccl_v_colloop:
   06CC 06 00         [ 7] 1515    ld b, #0                          ;; B = row window start (0..3)
   06CE                    1516 _mccl_v_rowloop:
   06CE C5            [11] 1517    push bc
                           1518 
   06CF 78            [ 4] 1519    ld a, b
