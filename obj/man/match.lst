   014B CD DF 00      [17]  389    call _match_col_row_to_screen_addr  ;; DE = screen addr
   014E 13            [ 6]  390    inc de                              ;; shift cursor 1 byte (2px) right within cell
                            391 
                            392    ;; Draw yellow solid box (cursor background, slightly smaller than cell)
   014F 3E 3C         [ 7]  393    ld a, #CURSOR_COLOR
