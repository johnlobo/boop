   01E0                     517 _mpp_do_place:
                            518    ;; board_value = _match_state*2 + _cursor_piece + 1
                            519    ;;   P1 cat=1, P1 kitten=2, P2 cat=3, P2 kitten=4
   01E0 3A 32 00      [13]  520    ld a, (_match_state)
   01E3 87            [ 4]  521    add a, a                          ;; A = state * 2
   01E4 47            [ 4]  522    ld b, a
   01E5 3A 35 00      [13]  523    ld a, (_cursor_piece)
   01E8 80            [ 4]  524    add a, b                          ;; A = state*2 + piece
   01E9 3C            [ 4]  525    inc a                             ;; A = state*2 + piece + 1
   01EA 77            [ 7]  526    ld (hl), a                        ;; write to board
                            527 
                            528    ;; Animate boop: frame0=placed, frame1=in-transit, frame2=destinations filled
   01EB CD 9F 03      [17]  529    call _match_boop_animate
   01EE CD 5E 05      [17]  530    call _match_check_lines           ;; check for 3 same-color pieces in a row
                            531 
