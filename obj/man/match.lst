                            452 ;;-----------------------------------------------------------------
                            453 ;;
                            454 ;; _match_place_piece
                            455 ;;
                            456 ;;  Places the current player's selected piece at the cursor position.
                            457 ;;  Does nothing if the cell is occupied or the player has no pieces left.
                            458 ;;  On success: decrements piece count, toggles state, redraws.
                            459 ;;  Input:
                            460 ;;  Output:
                            461 ;;  Modified: AF, BC, DE, HL, IX
                            462 ;;
   019F                     463 _match_place_piece:
                            464    ;; Compute board index = row*6 + col
   019F 3A 34 00      [13]  465    ld a, (_cursor_row)
   01A2 47            [ 4]  466    ld b, a                           ;; B = row
   01A3 07            [ 4]  467    rlca                              ;; A = row * 2
   01A4 07            [ 4]  468    rlca                              ;; A = row * 4
   01A5 80            [ 4]  469    add a, b                          ;; A = row * 5
   01A6 80            [ 4]  470    add a, b                          ;; A = row * 6
   01A7 47            [ 4]  471    ld b, a                           ;; B = row * 6
   01A8 3A 33 00      [13]  472    ld a, (_cursor_col)
   01AB 80            [ 4]  473    add a, b                          ;; A = row*6 + col
   01AC 4F            [ 4]  474    ld c, a
   01AD 06 00         [ 7]  475    ld b, #0
                            476 
                            477    ;; HL = &_match_board[idx]
   01AF 21 0D 00      [10]  478    ld hl, #_match_board
   01B2 09            [11]  479    add hl, bc
                            480 
                            481    ;; Check cell is empty
   01B3 7E            [ 7]  482    ld a, (hl)
   01B4 B7            [ 4]  483    or a
   01B5 C0            [11]  484    ret nz                            ;; occupied, do nothing
                            485 
                            486    ;; Load player struct into IX
ASxxxx Assembler V02.00 + NoICE + SDCC mods  (Zilog Z80 / Hitachi HD64180), page 116.
Hexadecimal [16-Bits]



   01B6 3A 32 00      [13]  487    ld a, (_match_state)
   01B9 B7            [ 4]  488    or a
   01BA 20 06         [12]  489    jr nz, _mpp_player2
   01BC DD 21 00 00   [14]  490    ld ix, #man_match_player1
   01C0 18 04         [12]  491    jr _mpp_got_player
