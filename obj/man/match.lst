   054E 3E 01         [ 7] 1230    ld a, #1
   0550 21 4D 00      [10] 1231    ld hl, #_match_p1_wins_msg
   0553 18 05         [12] 1232    jr _mdw_show
   0555                    1233 _mdw_p2:
