                            257 ;; _match_col_row_to_screen_addr
                            258 ;;
                            259 ;;  Converts a grid (col, row) position to a video memory address.
                            260 ;;  Input:  C = col (0 .. GRID_COLS-1)
                            261 ;;          B = row (0 .. GRID_ROWS-1)
                            262 ;;  Output: DE = screen address
                            263 ;;  Modified: AF, BC, DE, HL
                            264 ;;
   00DF                     265 _match_col_row_to_screen_addr:
                            266    ;; Y = GRID_FIRST_CELL_Y + row * GRID_CELL_H  (row*24 = row*16 + row*8)
                            267    ;; Computed first so we can use E as a temporary before DE is set for the call
   00DF 78            [ 4]  268    ld a, b
   00E0 87            [ 4]  269    add a, a                          ;; A = row * 2
   00E1 87            [ 4]  270    add a, a                          ;; A = row * 4
   00E2 87            [ 4]  271    add a, a                          ;; A = row * 8
   00E3 5F            [ 4]  272    ld e, a                           ;; E = row * 8  (temp; DE overwritten below)
   00E4 87            [ 4]  273    add a, a                          ;; A = row * 16
ASxxxx Assembler V02.00 + NoICE + SDCC mods  (Zilog Z80 / Hitachi HD64180), page 111.
Hexadecimal [16-Bits]



   00E5 83            [ 4]  274    add a, e                          ;; A = row * 24
   00E6 C6 24         [ 7]  275    add a, #GRID_FIRST_CELL_Y
   00E8 47            [ 4]  276    ld b, a                           ;; B = Y pixel row
                            277 
                            278    ;; X = GRID_FIRST_CELL_X + col * GRID_CELL_W  (col*7 = col*8 - col)
   00E9 79            [ 4]  279    ld a, c
   00EA 87            [ 4]  280    add a, a                          ;; A = col * 2
   00EB 87            [ 4]  281    add a, a                          ;; A = col * 4
   00EC 87            [ 4]  282    add a, a                          ;; A = col * 8
   00ED 91            [ 4]  283    sub c                             ;; A = col*8 - col = col * 7  (C still = col)
   00EE C6 13         [ 7]  284    add a, #GRID_FIRST_CELL_X
   00F0 4F            [ 4]  285    ld c, a                           ;; C = X byte offset
                            286 
   00F1 11 00 C0      [10]  287    ld de, #CPCT_VMEM_START_ASM
   00F4 CD 00 00      [17]  288    call cpct_getScreenPtr_asm        ;; HL = screen address
   00F7 EB            [ 4]  289    ex de, hl                         ;; DE = screen address
   00F8 C9            [10]  290    ret
                            291 
                            292 ;;-----------------------------------------------------------------
                            293 ;;
                            294 ;; _match_draw_cell_sprite
                            295 ;;
                            296 ;;  Draws the masked sprite for a given board cell value.
                            297 ;;  Input:  A  = board value (1-4)
                            298 ;;          DE = screen destination address
                            299 ;;  Output:
                            300 ;;  Modified: AF, BC, DE, HL, IX
                            301 ;;
   00F9                     302 _match_draw_cell_sprite:
   00F9 D5            [11]  303    push de                           ;; save screen address
   00FA 3D            [ 4]  304    dec a                             ;; A = 0-3 (table index)
   00FB 21 97 00      [10]  305    ld hl, #_board_sprite_ptrs
   00FE 06 00         [ 7]  306    ld b, #0
   0100 4F            [ 4]  307    ld c, a
   0101 CB 21         [ 8]  308    sla c                             ;; C = index * 2
   0103 CB 10         [ 8]  309    rl b
   0105 09            [11]  310    add hl, bc                        ;; HL = &_board_sprite_ptrs[index]
   0106 4E            [ 7]  311    ld c, (hl)
   0107 23            [ 6]  312    inc hl
   0108 46            [ 7]  313    ld b, (hl)                        ;; BC = sprite data pointer
   0109 D1            [10]  314    pop de                            ;; restore screen address
   010A                     315    ld__ixl S_CAT_W
   010A DD 2E 05              1    .db #0xDD, #0x2E, S_CAT_W  ;; Opcode for ld ixl, Value
   010D                     316    ld__ixh S_CAT_H
   010D DD 26 11              1    .db #0xDD, #0x26, S_CAT_H  ;; Opcode for ld ixh, Value
   0110 21 00 00      [10]  317    ld hl, #transparency_table
   0113 CD 00 00      [17]  318    call cpct_drawSpriteMaskedAlignedTable_asm
   0116 C9            [10]  319    ret
                            320 
                            321 ;;-----------------------------------------------------------------
                            322 ;;
                            323 ;; _match_draw_board
                            324 ;;
                            325 ;;  Iterates all 6x6 cells and draws sprites for non-empty ones.
                            326 ;;  Input:
ASxxxx Assembler V02.00 + NoICE + SDCC mods  (Zilog Z80 / Hitachi HD64180), page 112.
Hexadecimal [16-Bits]



                            327 ;;  Output:
                            328 ;;  Modified: AF, BC, DE, HL, IX
                            329 ;;
   0117                     330 _match_draw_board:
   0117 DD 21 0D 00   [14]  331    ld ix, #_match_board
   011B 06 00         [ 7]  332    ld b, #0                          ;; B = row
   011D                     333 _mdb_row_loop:
   011D 0E 00         [ 7]  334    ld c, #0                          ;; C = col
   011F                     335 _mdb_col_loop:
   011F DD 7E 00      [19]  336    ld a, 0(ix)                       ;; A = cell value
   0122 DD 23         [10]  337    inc ix                            ;; advance board pointer
   0124 B7            [ 4]  338    or a
   0125 28 0F         [12]  339    jr z, _mdb_next_col               ;; skip empty cells
                            340 
   0127 DD E5         [15]  341    push ix                           ;; save board pointer (clobbered by sprite draw)
   0129 C5            [11]  342    push bc                           ;; save row (B) and col (C)
   012A F5            [11]  343    push af                           ;; save cell value
   012B CD DF 00      [17]  344    call _match_col_row_to_screen_addr ;; B=row, C=col -> DE = screen addr
   012E F1            [10]  345    pop af                            ;; A = cell value
   012F 13            [ 6]  346    inc de                            ;; shift sprite 1 byte (2px) right, same as cursor
   0130 CD F9 00      [17]  347    call _match_draw_cell_sprite
   0133 C1            [10]  348    pop bc                            ;; restore row/col
   0134 DD E1         [14]  349    pop ix                            ;; restore board pointer
                            350 
   0136                     351 _mdb_next_col:
   0136 0C            [ 4]  352    inc c
   0137 79            [ 4]  353    ld a, c
   0138 FE 06         [ 7]  354    cp #GRID_COLS
   013A 38 E3         [12]  355    jr c, _mdb_col_loop
                            356 
   013C 04            [ 4]  357    inc b
   013D 78            [ 4]  358    ld a, b
   013E FE 06         [ 7]  359    cp #GRID_ROWS
   0140 38 DB         [12]  360    jr c, _mdb_row_loop
                            361 
   0142 C9            [10]  362    ret
