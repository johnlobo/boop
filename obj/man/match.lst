                            101 ;;   index 3 (value 4) -> P2 kitten
                            102 ;;
   0097                     103 _board_sprite_ptrs:
   0097 00 00               104    .dw _s_cat_0
   0099 00 00               105    .dw _s_catty_0
   009B 00 00               106    .dw _s_cat_1
   009D 00 00               107    .dw _s_catty_1
