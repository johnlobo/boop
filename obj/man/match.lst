                             40 ;;
                             41 ;; Start of _DATA area
                             42 ;;
                             43 .area _DATA
                             44 
   0000                      45 man_match_player1:: .ds sizeof_Player
   0006                      46 man_match_player2:: .ds sizeof_Player
   000C 01                   47 man_match_num_players:: .db 1
                             48 
                             49 ;;
                             50 ;; Board: 6x6 cells, row-major [row*6 + col]
                             51 ;; Values: 0=empty, 1=P1 cat, 2=P1 kitten, 3=P2 cat, 4=P2 kitten
                             52 ;;
   000D                      53 _match_board: .ds 36
                             54 
                             55 ;;
                             56 ;; Turn / cursor state
                             57 ;;
   0031 00                   58 _match_cancelled:: .db 0 ;; set to 1 when player confirms ESC → abandon match
   0032 00                   59 _match_state:      .db 0 ;; MATCH_STATE_P1 or MATCH_STATE_P2
   0033 00                   60 _cursor_col:    .db 0   ;; 0 .. GRID_COLS-1
   0034 00                   61 _cursor_row:    .db 0   ;; 0 .. GRID_ROWS-1
   0035 00                   62 _cursor_piece:  .db 0   ;; PIECE_CAT or PIECE_KITTEN
   0036 00                   63 _turn_debounce: .db 0   ;; 1 while a key is held (same pattern as menu.s)
                             64 
                             65 ;;
                             66 ;; Boop animation buffers
                             67 ;;
   0037                      68 _boop_anim_before: .ds 36     ;; pre-boop board snapshot (36 cells)
   005B                      69 _boop_transit_buf: .ds 16     ;; destinations in-transit: 8 × (offset byte, value byte)
   006B 00                   70 _boop_transit_cnt: .db 0      ;; number of valid entries in _boop_transit_buf
                             71 
   006C 20 41 42 41 4E 44    72 _match_cancel_msg:  .asciz " ABANDON MATCH? (Y/N)"
        4F 4E 20 4D 41 54
        43 48 3F 20 28 59
        2F 4E 29 00
   0082 20 20 20 20 50 4C    73 _match_p1_wins_msg: .asciz "    PLAYER 1 WINS!"
        41 59 45 52 20 31
