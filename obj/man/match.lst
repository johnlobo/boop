        43 48 3F 20 28 59
        2F 4E 29 00
   004D 20 20 20 20 50 4C    65 _match_p1_wins_msg: .asciz "    PLAYER 1 WINS!"
        41 59 45 52 20 31
        20 57 49 4E 53 21
        00
   0060 20 20 20 20 50 4C    66 _match_p2_wins_msg: .asciz "    PLAYER 2 WINS!"
        41 59 45 52 20 32
