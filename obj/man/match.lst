                            806 ;;
                            807 ;; _match_boop_animate
                            808 ;;
                            809 ;;  Animates the boop in 3 visual frames:
                            810 ;;    Frame 0: piece placed, all others still at original positions (pre-boop)
ASxxxx Assembler V02.00 + NoICE + SDCC mods  (Zilog Z80 / Hitachi HD64180), page 122.
Hexadecimal [16-Bits]



                            811 ;;    Frame 1: boop sources cleared, destinations empty (in-transit)
                            812 ;;    Frame 2: pieces restored at boop destinations (post-boop)
                            813 ;;  Reads _cursor_piece to dispatch kitten vs cat boop.
                            814 ;;  Input:  _cursor_piece, _cursor_row, _cursor_col (board already updated with placed piece)
                            815 ;;  Output: _match_board in post-boop state
                            816 ;;  Modified: AF, BC, DE, HL, IX, IY
                            817 ;;
   039F                     818 _match_boop_animate:
                            819    ;; Frame 0: show piece placed, before any boop
   039F CD 95 01      [17]  820    call _match_redraw_all
   03A2 06 04         [ 7]  821    ld b, #4
   03A4 CD 00 00      [17]  822    call sys_util_delay
                            823 
                            824    ;; Save pre-boop board (before boop clears source cells)
   03A7 21 0D 00      [10]  825    ld hl, #_match_board
   03AA 11 37 00      [10]  826    ld de, #_boop_anim_before
   03AD 01 24 00      [10]  827    ld bc, #36
   03B0 ED B0         [21]  828    ldir
                            829 
                            830    ;; Execute boop (board → post-boop state)
   03B2 3A 35 00      [13]  831    ld a, (_cursor_piece)
   03B5 B7            [ 4]  832    or a
   03B6 28 05         [12]  833    jr z, _mba_cat
   03B8 CD 1C 04      [17]  834    call _match_boop
   03BB 18 03         [12]  835    jr _mba_after_boop
   03BD                     836 _mba_cat:
   03BD CD B1 04      [17]  837    call _match_boop_cat
                            838 
   03C0                     839 _mba_after_boop:
                            840    ;; Scan all 36 cells to find destinations:
                            841    ;; destination = empty in pre-boop AND non-empty in post-boop board
                            842    ;; Save each to transit buffer, then clear from board → intermediate state
   03C0 AF            [ 4]  843    xor a
   03C1 32 6B 00      [13]  844    ld (_boop_transit_cnt), a
   03C4 21 37 00      [10]  845    ld hl, #_boop_anim_before         ;; pre-boop snapshot
   03C7 11 0D 00      [10]  846    ld de, #_match_board              ;; post-boop (current board)
   03CA DD 21 5B 00   [14]  847    ld ix, #_boop_transit_buf
   03CE 06 24         [ 7]  848    ld b, #36                         ;; cell count
   03D0 0E 00         [ 7]  849    ld c, #0                          ;; cell index (0..35)
   03D2                     850 _mba_scan:
   03D2 7E            [ 7]  851    ld a, (hl)
   03D3 B7            [ 4]  852    or a
   03D4 20 17         [12]  853    jr nz, _mba_scan_next             ;; was non-empty before → not a destination
   03D6 1A            [ 7]  854    ld a, (de)
   03D7 B7            [ 4]  855    or a
   03D8 28 13         [12]  856    jr z, _mba_scan_next              ;; still empty → not a destination
                            857    ;; Found a destination: save offset + value, clear cell in board
   03DA DD 71 00      [19]  858    ld 0(ix), c                       ;; board offset
   03DD DD 77 01      [19]  859    ld 1(ix), a                       ;; piece value
   03E0 DD 23         [10]  860    inc ix
   03E2 DD 23         [10]  861    inc ix
   03E4 3A 6B 00      [13]  862    ld a, (_boop_transit_cnt)
   03E7 3C            [ 4]  863    inc a
   03E8 32 6B 00      [13]  864    ld (_boop_transit_cnt), a
   03EB AF            [ 4]  865    xor a
ASxxxx Assembler V02.00 + NoICE + SDCC mods  (Zilog Z80 / Hitachi HD64180), page 123.
Hexadecimal [16-Bits]



   03EC 12            [ 7]  866    ld (de), a                        ;; clear destination → intermediate state
   03ED                     867 _mba_scan_next:
   03ED 23            [ 6]  868    inc hl
   03EE 13            [ 6]  869    inc de
   03EF 0C            [ 4]  870    inc c
   03F0 05            [ 4]  871    dec b
   03F1 20 DF         [12]  872    jr nz, _mba_scan
                            873 
                            874    ;; Frame 1: show intermediate (sources gone, destinations not yet filled)
   03F3 CD 95 01      [17]  875    call _match_redraw_all
   03F6 06 03         [ 7]  876    ld b, #3
   03F8 CD 00 00      [17]  877    call sys_util_delay
