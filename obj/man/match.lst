   0085 00 00                86    .dw _s_big_numbers_01
   0087 00 00                87    .dw _s_big_numbers_02
   0089 00 00                88    .dw _s_big_numbers_03
   008B 00 00                89    .dw _s_big_numbers_04
   008D 00 00                90    .dw _s_big_numbers_05
