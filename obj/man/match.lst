                            265 ;;-----------------------------------------------------------------
                            266 ;;
                            267 ;; _match_col_row_to_screen_addr
                            268 ;;
                            269 ;;  Converts a grid (col, row) position to a video memory address.
                            270 ;;  Input:  C = col (0 .. GRID_COLS-1)
ASxxxx Assembler V02.00 + NoICE + SDCC mods  (Zilog Z80 / Hitachi HD64180), page 112.
Hexadecimal [16-Bits]



                            271 ;;          B = row (0 .. GRID_ROWS-1)
                            272 ;;  Output: DE = screen address
                            273 ;;  Modified: AF, BC, DE, HL
                            274 ;;
   00DF                     275 _match_col_row_to_screen_addr:
                            276    ;; Y = GRID_FIRST_CELL_Y + row * GRID_CELL_H  (row*24 = row*16 + row*8)
                            277    ;; Computed first so we can use E as a temporary before DE is set for the call
   00DF 78            [ 4]  278    ld a, b
   00E0 87            [ 4]  279    add a, a                          ;; A = row * 2
   00E1 87            [ 4]  280    add a, a                          ;; A = row * 4
   00E2 87            [ 4]  281    add a, a                          ;; A = row * 8
   00E3 5F            [ 4]  282    ld e, a                           ;; E = row * 8  (temp; DE overwritten below)
   00E4 87            [ 4]  283    add a, a                          ;; A = row * 16
   00E5 83            [ 4]  284    add a, e                          ;; A = row * 24
   00E6 C6 24         [ 7]  285    add a, #GRID_FIRST_CELL_Y
   00E8 47            [ 4]  286    ld b, a                           ;; B = Y pixel row
                            287 
                            288    ;; X = GRID_FIRST_CELL_X + col * GRID_CELL_W  (col*7 = col*8 - col)
   00E9 79            [ 4]  289    ld a, c
   00EA 87            [ 4]  290    add a, a                          ;; A = col * 2
   00EB 87            [ 4]  291    add a, a                          ;; A = col * 4
   00EC 87            [ 4]  292    add a, a                          ;; A = col * 8
   00ED 91            [ 4]  293    sub c                             ;; A = col*8 - col = col * 7  (C still = col)
   00EE C6 13         [ 7]  294    add a, #GRID_FIRST_CELL_X
   00F0 4F            [ 4]  295    ld c, a                           ;; C = X byte offset
                            296 
   00F1 11 00 C0      [10]  297    ld de, #CPCT_VMEM_START_ASM
   00F4 CD 00 00      [17]  298    call cpct_getScreenPtr_asm        ;; HL = screen address
   00F7 EB            [ 4]  299    ex de, hl                         ;; DE = screen address
   00F8 C9            [10]  300    ret
                            301 
                            302 ;;-----------------------------------------------------------------
                            303 ;;
                            304 ;; _match_draw_cell_sprite
                            305 ;;
                            306 ;;  Draws the masked sprite for a given board cell value.
                            307 ;;  Input:  A  = board value (1-4)
                            308 ;;          DE = screen destination address
                            309 ;;  Output:
                            310 ;;  Modified: AF, BC, DE, HL, IX
                            311 ;;
   00F9                     312 _match_draw_cell_sprite:
   00F9 D5            [11]  313    push de                           ;; save screen address
   00FA 3D            [ 4]  314    dec a                             ;; A = 0-3 (table index)
   00FB 21 E8 00      [10]  315    ld hl, #_board_sprite_ptrs
   00FE 06 00         [ 7]  316    ld b, #0
   0100 4F            [ 4]  317    ld c, a
   0101 CB 21         [ 8]  318    sla c                             ;; C = index * 2
   0103 CB 10         [ 8]  319    rl b
   0105 09            [11]  320    add hl, bc                        ;; HL = &_board_sprite_ptrs[index]
   0106 4E            [ 7]  321    ld c, (hl)
   0107 23            [ 6]  322    inc hl
   0108 46            [ 7]  323    ld b, (hl)                        ;; BC = sprite data pointer
   0109 D1            [10]  324    pop de                            ;; restore screen address
   010A                     325    ld__ixl S_CAT_W
ASxxxx Assembler V02.00 + NoICE + SDCC mods  (Zilog Z80 / Hitachi HD64180), page 113.
Hexadecimal [16-Bits]



   010A DD 2E 05              1    .db #0xDD, #0x2E, S_CAT_W  ;; Opcode for ld ixl, Value
   010D                     326    ld__ixh S_CAT_H
   010D DD 26 11              1    .db #0xDD, #0x26, S_CAT_H  ;; Opcode for ld ixh, Value
   0110 21 00 00      [10]  327    ld hl, #transparency_table
   0113 CD 00 00      [17]  328    call cpct_drawSpriteMaskedAlignedTable_asm
   0116 C9            [10]  329    ret
