                             31 ;; Cursor box dimensions (smaller than cell to leave gaps)
                             32 ;; Width: GRID_CELL_W - 1 byte = 2 pixels thinner
                             33 ;; Height: GRID_CELL_H - 2 pixels shorter
                     0005    34 CURSOR_W              = 5
