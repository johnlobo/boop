   0543 16 4E         [ 7] 1224    ld d, #78
   0545 06 23         [ 7] 1225    ld b, #35
   0547 0E 32         [ 7] 1226    ld c, #50
   0549 F1            [10] 1227    pop af                            ;; restore winner number
