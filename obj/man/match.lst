                           1033 ;;
                           1034 ;; _match_boop_cat
                           1035 ;;
                           1036 ;;  Called after placing a cat at (_cursor_row, _cursor_col).
                           1037 ;;  For each of 8 neighbor directions: if the neighbor cell holds
                           1038 ;;  any piece (kitten or cat), it is pushed one cell further away.
                           1039 ;;  If the destination is off-grid the piece is removed from the
                           1040 ;;  board and returned to its owner's reserve (kittens or cats).
                           1041 ;;  If the destination is occupied the piece stays in place.
                           1042 ;;  Input:  _cursor_row, _cursor_col = placed cat position
                           1043 ;;  Output:
                           1044 ;;  Modified: AF, BC, DE, HL, IX, IY
                           1045 ;;
   04B1                    1046 _match_boop_cat:
   04B1 FD 21 C4 00   [14] 1047    ld iy, #_boop_dir_table
   04B5 06 08         [ 7] 1048    ld b, #8                          ;; 8 directions to check
                           1049 
   04B7                    1050 _mbc_dir_loop:
   04B7 C5            [11] 1051    push bc                           ;; save loop counter
                           1052 
                           1053    ;; -- compute neighbor row: nr = cursor_row + dr --
   04B8 3A 34 00      [13] 1054    ld a, (_cursor_row)
   04BB FD 86 00      [19] 1055    add a, 0(iy)
   04BE FA 3D 05      [10] 1056    jp m, _mbc_next_dir               ;; nr < 0 → out of bounds
   04C1 57            [ 4] 1057    ld d, a                           ;; D = nr
   04C2 FE 06         [ 7] 1058    cp #GRID_ROWS
   04C4 30 77         [12] 1059    jr nc, _mbc_next_dir              ;; nr >= 6 → out of bounds
                           1060 
                           1061    ;; -- compute neighbor col: nc = cursor_col + dc --
   04C6 3A 33 00      [13] 1062    ld a, (_cursor_col)
   04C9 FD 86 01      [19] 1063    add a, 1(iy)
   04CC FA 3D 05      [10] 1064    jp m, _mbc_next_dir               ;; nc < 0 → out of bounds
   04CF 5F            [ 4] 1065    ld e, a                           ;; E = nc
   04D0 FE 06         [ 7] 1066    cp #GRID_COLS
   04D2 30 69         [12] 1067    jr nc, _mbc_next_dir              ;; nc >= 6 → out of bounds
                           1068 
                           1069    ;; -- look up board[nr][nc] --
   04D4 7A            [ 4] 1070    ld a, d
   04D5 87            [ 4] 1071    add a, a                          ;; row*2
   04D6 87            [ 4] 1072    add a, a                          ;; row*4
   04D7 82            [ 4] 1073    add a, d                          ;; row*5
   04D8 82            [ 4] 1074    add a, d                          ;; row*6
   04D9 83            [ 4] 1075    add a, e
   04DA 21 0D 00      [10] 1076    ld hl, #_match_board
   04DD 4F            [ 4] 1077    ld c, a
   04DE 06 00         [ 7] 1078    ld b, #0
   04E0 09            [11] 1079    add hl, bc                        ;; HL = &board[nr][nc]
                           1080 
   04E1 7E            [ 7] 1081    ld a, (hl)
   04E2 B7            [ 4] 1082    or a
   04E3 28 58         [12] 1083    jr z, _mbc_next_dir               ;; empty → nothing to push
                           1084 
   04E5                    1085 _mbc_is_piece:
