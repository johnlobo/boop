   015C 3A 34 00      [13]  401    ld a, (_cursor_row)
   015F 47            [ 4]  402    ld b, a
   0160 CD DF 00      [17]  403    call _match_col_row_to_screen_addr  ;; DE = screen addr
   0163 13            [ 6]  404    inc de                              ;; shift cursor 1 byte (2px) right within cell
                            405 
