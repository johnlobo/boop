                            122 .area _CODE
                            123 
                            124 ;;-----------------------------------------------------------------
                            125 ;;
                            126 ;; _match_init_player
                            127 ;;
                            128 ;;  Zeroes score and sets cats, kittens for one player struct
                            129 ;;  Input:  HL = pointer to player struct
                            130 ;;  Output:
                            131 ;;  Modified: AF, IX
                            132 ;;
   0000                     133 _match_init_player:
   0000 E5            [11]  134    push hl
   0001 DD E1         [14]  135    pop ix                            ;; IX = player struct pointer (IX supports displacement)
   0003 AF            [ 4]  136    xor a
   0004 DD 77 00      [19]  137    ld Player_score+0(ix), a
   0007 DD 77 01      [19]  138    ld Player_score+1(ix), a
   000A DD 77 02      [19]  139    ld Player_score+2(ix), a
   000D DD 77 03      [19]  140    ld Player_score+3(ix), a
   0010 3E 00         [ 7]  141    ld a, #MATCH_INITIAL_CATS
   0012 DD 77 04      [19]  142    ld Player_cats(ix), a
   0015 3E 08         [ 7]  143    ld a, #MATCH_INITIAL_KITTENS
   0017 DD 77 05      [19]  144    ld Player_kittens(ix), a
   001A C9            [10]  145    ret
                            146 
                            147 ;;-----------------------------------------------------------------
                            148 ;;
                            149 ;; _draw_big_digit
                            150 ;;
                            151 ;;  Draws a single big number sprite at the given screen address.
                            152 ;;  Input:  A  = digit (0-9)
                            153 ;;          DE = screen destination address
                            154 ;;  Output:
                            155 ;;  Modified: AF, BC, HL
                            156 ;;
   001B                     157 _draw_big_digit:
   001B D5            [11]  158    push de                           ;; save dest while computing sprite ptr
   001C 21 D4 00      [10]  159    ld hl, #_big_num_ptrs
   001F 06 00         [ 7]  160    ld b, #0
   0021 4F            [ 4]  161    ld c, a
   0022 CB 21         [ 8]  162    sla c                             ;; C = digit * 2 (each table entry = 2 bytes)
   0024 CB 10         [ 8]  163    rl b                              ;; carry into B (always 0 for digits 0-9)
   0026 09            [11]  164    add hl, bc                        ;; HL = &_big_num_ptrs[digit * 2]
   0027 4E            [ 7]  165    ld c, (hl)
   0028 23            [ 6]  166    inc hl
   0029 46            [ 7]  167    ld b, (hl)                        ;; BC = sprite data pointer
   002A D1            [10]  168    pop de                            ;; restore dest
   002B                     169    ld__ixl S_BIG_NUMBERS_W
   002B DD 2E 03              1    .db #0xDD, #0x2E, S_BIG_NUMBERS_W  ;; Opcode for ld ixl, Value
   002E                     170    ld__ixh S_BIG_NUMBERS_H
   002E DD 26 0D              1    .db #0xDD, #0x26, S_BIG_NUMBERS_H  ;; Opcode for ld ixh, Value
   0031 21 00 00      [10]  171    ld hl, #transparency_table
   0034 CD 00 00      [17]  172    call cpct_drawSpriteMaskedAlignedTable_asm
   0037 C9            [10]  173    ret
                            174 
ASxxxx Assembler V02.00 + NoICE + SDCC mods  (Zilog Z80 / Hitachi HD64180), page 110.
