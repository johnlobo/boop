                            442 ;;-----------------------------------------------------------------
                            443 ;;
                            444 ;; _match_place_piece
                            445 ;;
                            446 ;;  Places the current player's selected piece at the cursor position.
                            447 ;;  Does nothing if the cell is occupied or the player has no pieces left.
                            448 ;;  On success: decrements piece count, toggles state, redraws.
                            449 ;;  Input:
                            450 ;;  Output:
                            451 ;;  Modified: AF, BC, DE, HL, IX
                            452 ;;
   019F                     453 _match_place_piece:
                            454    ;; Compute board index = row*6 + col
   019F 3A 34 00      [13]  455    ld a, (_cursor_row)
   01A2 47            [ 4]  456    ld b, a                           ;; B = row
   01A3 07            [ 4]  457    rlca                              ;; A = row * 2
   01A4 07            [ 4]  458    rlca                              ;; A = row * 4
   01A5 80            [ 4]  459    add a, b                          ;; A = row * 5
   01A6 80            [ 4]  460    add a, b                          ;; A = row * 6
   01A7 47            [ 4]  461    ld b, a                           ;; B = row * 6
   01A8 3A 33 00      [13]  462    ld a, (_cursor_col)
   01AB 80            [ 4]  463    add a, b                          ;; A = row*6 + col
   01AC 4F            [ 4]  464    ld c, a
   01AD 06 00         [ 7]  465    ld b, #0
                            466 
                            467    ;; HL = &_match_board[idx]
   01AF 21 0D 00      [10]  468    ld hl, #_match_board
   01B2 09            [11]  469    add hl, bc
                            470 
                            471    ;; Check cell is empty
   01B3 7E            [ 7]  472    ld a, (hl)
   01B4 B7            [ 4]  473    or a
   01B5 C0            [11]  474    ret nz                            ;; occupied, do nothing
                            475 
                            476    ;; Load player struct into IX
   01B6 3A 32 00      [13]  477    ld a, (_match_state)
   01B9 B7            [ 4]  478    or a
   01BA 20 06         [12]  479    jr nz, _mpp_player2
   01BC DD 21 00 00   [14]  480    ld ix, #man_match_player1
   01C0 18 04         [12]  481    jr _mpp_got_player
   01C2                     482 _mpp_player2:
   01C2 DD 21 06 00   [14]  483    ld ix, #man_match_player2
                            484 
   01C6                     485 _mpp_got_player:
                            486    ;; Check/decrement piece count; HL still points to board cell
   01C6 3A 35 00      [13]  487    ld a, (_cursor_piece)
   01C9 B7            [ 4]  488    or a
   01CA 20 0B         [12]  489    jr nz, _mpp_check_kitten
ASxxxx Assembler V02.00 + NoICE + SDCC mods  (Zilog Z80 / Hitachi HD64180), page 115.
Hexadecimal [16-Bits]



                            490 
                            491    ;; CAT
   01CC DD 7E 04      [19]  492    ld a, Player_cats(ix)
   01CF B7            [ 4]  493    or a
   01D0 C8            [11]  494    ret z                             ;; no cats left
   01D1 3D            [ 4]  495    dec a
   01D2 DD 77 04      [19]  496    ld Player_cats(ix), a
   01D5 18 09         [12]  497    jr _mpp_do_place
                            498 
   01D7                     499 _mpp_check_kitten:
                            500    ;; KITTEN
   01D7 DD 7E 05      [19]  501    ld a, Player_kittens(ix)
   01DA B7            [ 4]  502    or a
   01DB C8            [11]  503    ret z                             ;; no kittens left
   01DC 3D            [ 4]  504    dec a
   01DD DD 77 05      [19]  505    ld Player_kittens(ix), a
                            506 
   01E0                     507 _mpp_do_place:
                            508    ;; board_value = _match_state*2 + _cursor_piece + 1
                            509    ;;   P1 cat=1, P1 kitten=2, P2 cat=3, P2 kitten=4
   01E0 3A 32 00      [13]  510    ld a, (_match_state)
   01E3 87            [ 4]  511    add a, a                          ;; A = state * 2
   01E4 47            [ 4]  512    ld b, a
   01E5 3A 35 00      [13]  513    ld a, (_cursor_piece)
   01E8 80            [ 4]  514    add a, b                          ;; A = state*2 + piece
   01E9 3C            [ 4]  515    inc a                             ;; A = state*2 + piece + 1
   01EA 77            [ 7]  516    ld (hl), a                        ;; write to board
                            517 
                            518    ;; Boop: kittens push neighboring kittens; cats push kittens and cats
   01EB 3A 35 00      [13]  519    ld a, (_cursor_piece)
   01EE B7            [ 4]  520    or a
   01EF 28 05         [12]  521    jr z, _mpp_boop_cat               ;; PIECE_CAT = 0
   01F1 CD 3B 03      [17]  522    call _match_boop
   01F4 18 03         [12]  523    jr _mpp_do_check
   01F6                     524 _mpp_boop_cat:
   01F6 CD D0 03      [17]  525    call _match_boop_cat
   01F9                     526 _mpp_do_check:
   01F9 CD 7D 04      [17]  527    call _match_check_lines           ;; check for 3 same-color pieces in a row
                            528 
                            529    ;; After boop + line resolution: check if placing player has no pieces left
                            530    ;; (boop may have ejected their own pieces back; lines may have converted some)
   01FC 3A 32 00      [13]  531    ld a, (_match_state)              ;; still = placing player (not yet toggled)
   01FF B7            [ 4]  532    or a
   0200 20 06         [12]  533    jr nz, _mpp_pe_p2
   0202 DD 21 00 00   [14]  534    ld ix, #man_match_player1
   0206 18 04         [12]  535    jr _mpp_pe_chk
   0208                     536 _mpp_pe_p2:
   0208 DD 21 06 00   [14]  537    ld ix, #man_match_player2
   020C                     538 _mpp_pe_chk:
   020C DD 7E 04      [19]  539    ld a, Player_cats(ix)
   020F B7            [ 4]  540    or a
   0210 20 06         [12]  541    jr nz, _mpp_pe_done
   0212 DD 7E 05      [19]  542    ld a, Player_kittens(ix)
   0215 B7            [ 4]  543    or a
   0216 28 26         [12]  544    jr z, _mpp_pe_out                 ;; 0 cats and 0 kittens → opponent wins
ASxxxx Assembler V02.00 + NoICE + SDCC mods  (Zilog Z80 / Hitachi HD64180), page 116.
Hexadecimal [16-Bits]



   0218                     545 _mpp_pe_done:
                            546 
                            547    ;; Toggle state, reset piece selection to kitten
   0218 3A 32 00      [13]  548    ld a, (_match_state)
   021B EE 01         [ 7]  549    xor #1
   021D 32 32 00      [13]  550    ld (_match_state), a
   0220 3E 01         [ 7]  551    ld a, #PIECE_KITTEN
   0222 32 35 00      [13]  552    ld (_cursor_piece), a
                            553 
                            554    ;; Move cursor to top corner for next player's turn
                            555    ;; P1 -> top-left (col 0, row 0), P2 -> top-right (col 5, row 0)
   0225 AF            [ 4]  556    xor a
   0226 32 34 00      [13]  557    ld (_cursor_row), a
   0229 3A 32 00      [13]  558    ld a, (_match_state)
   022C B7            [ 4]  559    or a
   022D 28 02         [12]  560    jr z, _mpp_cursor_p1
   022F 3E 05         [ 7]  561    ld a, #(GRID_COLS - 1)
   0231                     562 _mpp_cursor_p1:
   0231 32 33 00      [13]  563    ld (_cursor_col), a
                            564 
   0234 CD 95 01      [17]  565    call _match_redraw_all
   0237 CD 38 00      [17]  566    call man_match_draw_hud
   023A CD 63 05      [17]  567    call _match_check_cat_lines       ;; check 3 cats in a row → winner
   023D C9            [10]  568    ret
                            569 
   023E                     570 _mpp_pe_out:
                            571    ;; Placing player is out of pieces after resolution → redraw, opponent wins
   023E CD 95 01      [17]  572    call _match_redraw_all
   0241 CD 38 00      [17]  573    call man_match_draw_hud
   0244 3A 32 00      [13]  574    ld a, (_match_state)              ;; placing player: 0=P1, 1=P2
   0247 EE 01         [ 7]  575    xor #1
   0249 3C            [ 4]  576    inc a                             ;; winner: state=0→2(P2), state=1→1(P1)
   024A C3 36 05      [10]  577    jp _match_declare_winner
