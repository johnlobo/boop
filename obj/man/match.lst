   057C 28 28         [12] 1243    jr z, _mcl_h_next                 ;; empty
   057E FE 03         [ 7] 1244    cp #3
   0580 30 24         [12] 1245    jr nc, _mcl_h_next                ;; P2 piece → mismatch
   0582 23            [ 6] 1246    inc hl
   0583 7E            [ 7] 1247    ld a, (hl)
   0584 B7            [ 4] 1248    or a
   0585 28 1F         [12] 1249    jr z, _mcl_h_next                 ;; empty
   0587 FE 03         [ 7] 1250    cp #3
