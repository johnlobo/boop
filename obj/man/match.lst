   026A                     617 _match_handle_input:
                            618    ;; Debounce: wait for full key release before accepting new input
   026A 3A 36 00      [13]  619    ld a, (_turn_debounce)
   026D B7            [ 4]  620    or a
   026E 28 0A         [12]  621    jr z, _mhi_check_keys
